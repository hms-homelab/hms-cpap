# HMS-CPAP Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# CPAP Device Configuration
# =============================================================================

# Device identification (appears in Home Assistant)
CPAP_DEVICE_ID=resmed_airsense10
CPAP_DEVICE_NAME=ResMed AirSense 10

# =============================================================================
# ez Share WiFi SD Card Configuration
# =============================================================================

# ez Share WiFi SD card base URL
# Default: http://192.168.4.1 (ez Share AP mode)
# For bridge setup: http://BRIDGE_IP:81 (e.g., http://192.168.1.100:81)
EZSHARE_BASE_URL=http://192.168.4.1

# Collection interval in seconds (default: 120 = 2 minutes)
# Recommended: 120-300 seconds to balance data freshness and network load
BURST_INTERVAL=120

# =============================================================================
# Storage Configuration
# =============================================================================

# Temporary file storage (for processing)
CPAP_TEMP_DIR=/tmp/hms-cpap

# Permanent archive directory (for long-term storage)
CPAP_ARCHIVE_DIR=/data/cpap_archive

# =============================================================================
# PostgreSQL Database (Optional - for historical data and ML)
# =============================================================================

# Database host (use "postgres" if using docker-compose)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cpap_data
DB_USER=cpap_user
DB_PASSWORD=changeme_secure_password

# =============================================================================
# MQTT Broker Configuration (Required for Home Assistant integration)
# =============================================================================

# MQTT broker address (use "mosquitto" if using docker-compose)
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USER=mqtt_user
MQTT_PASSWORD=changeme_secure_password

# MQTT client ID (must be unique if running multiple instances)
MQTT_CLIENT_ID=hms_cpap

# =============================================================================
# Health Check & Monitoring
# =============================================================================

# HTTP health check endpoint port
# Accessible at http://localhost:8893/health
HEALTH_CHECK_PORT=8893

# =============================================================================
# Advanced Configuration (Optional)
# =============================================================================

# Enable verbose logging (true/false)
# VERBOSE_LOGGING=false

# Archive retention days (future feature)
# ARCHIVE_RETENTION_DAYS=365
